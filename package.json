{
  "name": "pokemon-card-tracker",
  "version": "1.0.0",
  "description": "Scans major retailers for Pokemon card booster boxes and elite trainer boxes, with availability notifications",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "scan": "node src/scan-now.js",
    "test": "node --test src/**/*.test.js"
  },
  "keywords": ["pokemon", "tcg", "tracker", "stock", "notifications"],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "cheerio": "^1.0.0",
    "express": "^4.21.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.0",
    "random-useragent": "^0.5.0"
  }
}
