# Discord bot token (required)
# Create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_bot_token_here

# Local directory for staging downloads before upload
DOWNLOAD_DIR=./downloads

# Google Drive service account credentials JSON file
GOOGLE_CREDENTIALS_FILE=credentials.json

# Google Drive folder ID to upload into (the alphanumeric ID from the folder URL)
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Max concurrent downloads (default: 5)
MAX_CONCURRENT_DOWNLOADS=5

# Automatically scrape when bot joins a new server (default: true)
SCRAPE_ON_JOIN=true

# Max messages to scan per channel (0 = unlimited)
SCRAPE_HISTORY_LIMIT=0

# Max file size in MB to download (0 = unlimited)
MAX_FILE_SIZE_MB=100
