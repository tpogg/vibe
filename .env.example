# Domain Watchlist Bot Configuration
# Copy to .env and fill in your values

# ExpiredDomains.net credentials (free account)
ED_USERNAME=
ED_PASSWORD=

# Open PageRank API key (free: 10K req/day — https://www.domcop.com/openpagerank/)
OPENPAGERANK_API_KEY=

# WhoisXML API key (free: 500 queries — https://whoisxmlapi.com/)
WHOISXML_API_KEY=

# Registrar API credentials (pick one or both)
# GoDaddy (https://developer.godaddy.com/)
GODADDY_API_KEY=
GODADDY_API_SECRET=

# Dynadot (https://www.dynadot.com/account/domain/setting/api.html)
DYNADOT_API_KEY=

# Scoring thresholds
MIN_DOMAIN_AGE_YEARS=3
MIN_BACKLINKS=10
MIN_DOMAIN_AUTHORITY=15
MAX_PRICE_USD=500

# Watchlist settings
WATCHLIST_PATH=data/watchlist.json
CHECK_INTERVAL_HOURS=6
