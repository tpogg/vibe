# ============================================================
# Mode 1: Bot (use /scrape slash commands in Discord)
# ============================================================

# Discord bot token — create at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# Your Discord user ID — only you can run /scrape commands
# (Right-click your name in Discord -> Copy User ID)
OWNER_ID=0

# ============================================================
# Mode 2: CLI (one-shot export via DiscordChatExporter)
# ============================================================

# Your Discord user token (browser DevTools -> Network -> Authorization header)
DISCORD_TOKEN=

# Path to DiscordChatExporter CLI executable
DCE_PATH=DiscordChatExporter.Cli

# ============================================================
# Shared Settings
# ============================================================

# Local directories
DOWNLOAD_DIR=./downloads
EXPORT_DIR=./exports
ORGANIZED_DIR=./organized

# Google Drive service account credentials JSON
GOOGLE_CREDENTIALS_FILE=credentials.json

# Google Drive folder ID to upload into (from the folder URL)
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Max concurrent downloads for bot mode (default: 5)
MAX_CONCURRENT_DOWNLOADS=5

# Max file size in MB (0 = unlimited)
MAX_FILE_SIZE_MB=0
