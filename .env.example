# Your Discord token (required for export)
# How to get it: Open Discord in browser -> DevTools (F12) -> Network tab ->
# send any message -> find a request to discord.com -> copy the "Authorization" header value
DISCORD_TOKEN=

# Path to DiscordChatExporter CLI executable
# Download from: https://github.com/Tyrrrz/DiscordChatExporter/releases
# If it's on your PATH, just use the binary name
DCE_PATH=DiscordChatExporter.Cli

# Local directories
EXPORT_DIR=./exports
ORGANIZED_DIR=./organized

# Google Drive service account credentials JSON file (optional — only for cloud upload)
GOOGLE_CREDENTIALS_FILE=credentials.json

# Google Drive folder ID to upload into (from the folder URL)
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Max file size in MB to include (0 = unlimited)
MAX_FILE_SIZE_MB=0
