# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Your channel username (e.g. @vibeterminal) or numeric ID (e.g. -1001234567890)
# For private groups/channels, use the numeric ID (e.g. -1001234567890)
# Invite link: https://t.me/+1uBHW1JjfFNiNGM5
TELEGRAM_CHANNEL_ID=your-channel-id-here

# Your personal Telegram chat ID (so the bot can forward DMs to you)
# To find it: message @userinfobot on Telegram
TELEGRAM_OWNER_CHAT_ID=your-chat-id-here
